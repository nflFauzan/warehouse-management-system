<!-- Critical Stock Alert -->
<% if (stats.critical_items > 0) { %>
<div class="alert-critical mb-6 flex items-center gap-3">
  <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
  <div>
    <p class="font-semibold text-sm">⚠️ Peringatan Stok Kritis</p>
    <p class="text-xs mt-0.5"><%= stats.critical_items %> item memiliki stok di bawah batas minimum.
      <a href="/stock?status=critical" class="underline font-semibold hover:text-yellow-700">Lihat Detail →</a>
    </p>
  </div>
</div>
<% } %>

<!-- Stat Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
  <div class="card flex items-center gap-5 hover:shadow-md transition-shadow">
    <div class="w-14 h-14 bg-blue-primary rounded-full flex items-center justify-center flex-shrink-0 shadow-sm">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
    </div>
    <div>
      <p class="text-xs text-gray-400 font-medium mb-0.5">Total SKU Aktif</p>
      <p class="text-2xl font-bold text-dark-gray font-mono"><%= stats.total_sku %></p>
      <p class="text-[11px] text-gray-400">Item</p>
    </div>
  </div>
  <div class="card flex items-center gap-5 hover:shadow-md transition-shadow">
    <div class="w-14 h-14 bg-success rounded-full flex items-center justify-center flex-shrink-0 shadow-sm">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
    </div>
    <div>
      <p class="text-xs text-gray-400 font-medium mb-0.5">Masuk Hari Ini</p>
      <p class="text-2xl font-bold text-dark-gray font-mono"><%= stats.in_today %></p>
      <p class="text-[11px] text-gray-400">Transaksi</p>
    </div>
  </div>
  <div class="card flex items-center gap-5 hover:shadow-md transition-shadow">
    <div class="w-14 h-14 bg-danger rounded-full flex items-center justify-center flex-shrink-0 shadow-sm">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </div>
    <div>
      <p class="text-xs text-gray-400 font-medium mb-0.5">Keluar Hari Ini</p>
      <p class="text-2xl font-bold text-dark-gray font-mono"><%= stats.out_today %></p>
      <p class="text-[11px] text-gray-400">Transaksi</p>
    </div>
  </div>
  <div class="card flex items-center gap-5 hover:shadow-md transition-shadow">
    <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0 shadow-sm <%= stats.critical_items > 0 ? 'bg-yellow-accent' : 'bg-gray-200' %>">
      <svg class="w-6 h-6 <%= stats.critical_items > 0 ? 'text-dark-gray' : 'text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
    </div>
    <div>
      <p class="text-xs text-gray-400 font-medium mb-0.5">Stok Kritis</p>
      <p class="text-2xl font-bold font-mono <%= stats.critical_items > 0 ? 'text-danger' : 'text-gray-400' %>"><%= stats.critical_items %></p>
      <p class="text-[11px] text-gray-400">Item</p>
    </div>
  </div>
</div>

<!-- Grid: Recent + Chart -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <!-- Recent Transactions -->
  <div class="card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-bold text-dark-gray uppercase tracking-wider">Transaksi Terbaru</h2>
      <a href="/stock" class="text-xs text-blue-primary hover:underline font-medium">Lihat Semua →</a>
    </div>
    <div class="space-y-2.5">
      <% if (recent_transactions.length === 0) { %>
        <p class="text-sm text-gray-400 text-center py-6">Belum ada transaksi</p>
      <% } %>
      <% recent_transactions.forEach(function(tx) { %>
        <div class="flex items-center gap-3 py-2 border-b border-gray-50 last:border-0">
          <span class="<%= tx.type === 'in' ? 'badge-in' : 'badge-out' %> text-[10px] w-12 text-center">
            <%= tx.type === 'in' ? 'IN' : 'OUT' %>
          </span>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-dark-gray truncate"><%= tx.item ? tx.item.name : '-' %></p>
            <p class="text-xs text-gray-400"><%= tx.item ? tx.item.code : '' %> · <%= tx.createdBy ? tx.createdBy.name : '' %></p>
          </div>
          <div class="text-right">
            <p class="text-sm font-bold font-mono <%= tx.type === 'in' ? 'text-success' : 'text-danger' %>">
              <%= tx.type === 'in' ? '+' : '-' %><%= formatNumber(tx.quantity) %>
            </p>
            <p class="text-xs text-gray-400"><%= formatDate(tx.created_at) %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Chart + Quick Actions -->
  <div class="space-y-4">
    <div class="card">
      <h2 class="text-sm font-bold text-dark-gray uppercase tracking-wider mb-4">Aktivitas 7 Hari Terakhir</h2>
      <div class="h-[200px]">
        <canvas id="weeklyChart"></canvas>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <a href="/transaksi/masuk/create" class="btn-primary text-center py-4 rounded-xl flex items-center justify-center gap-2 no-underline shadow-sm hover:shadow-md transition-shadow">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Barang Masuk
      </a>
      <a href="/transaksi/keluar/create" class="btn-secondary text-center py-4 rounded-xl flex items-center justify-center gap-2 no-underline shadow-sm hover:shadow-md transition-shadow">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Barang Keluar
      </a>
    </div>
  </div>
</div>

<!-- Critical Items Table -->
<% if (critical_items.length > 0) { %>
<div class="card">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-bold text-danger uppercase tracking-wider">Item Stok Kritis</h2>
    <a href="/stock?status=critical" class="text-xs text-blue-primary hover:underline font-medium">Lihat Semua →</a>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="table-header">
          <th class="text-left py-2.5 px-3">Kode</th>
          <th class="text-left py-2.5 px-3">Nama Barang</th>
          <th class="text-left py-2.5 px-3">Kategori</th>
          <th class="text-right py-2.5 px-3">Stok</th>
          <th class="text-right py-2.5 px-3">Min.</th>
        </tr>
      </thead>
      <tbody>
        <% critical_items.forEach(function(item) { %>
        <tr class="bg-[#FFF5F5] border-b border-red-100">
          <td class="py-2.5 px-3 font-mono text-xs"><%= item.code %></td>
          <td class="py-2.5 px-3 font-medium"><%= item.name %></td>
          <td class="py-2.5 px-3 text-gray-500"><%= item.category ? item.category.name : '-' %></td>
          <td class="py-2.5 px-3 text-right font-mono font-bold text-danger"><%= formatNumber(item.current_stock) %> <span class="text-gray-400 font-normal"><%= item.unit ? item.unit.abbr : '' %></span></td>
          <td class="py-2.5 px-3 text-right font-mono text-gray-500"><%= formatNumber(item.minimum_stock) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const ctx = document.getElementById('weeklyChart');
  if (ctx) {
    const chartData = <%- JSON.stringify(chart_data) %>;
    new Chart(ctx.getContext('2d'), {
      type: 'bar',
      data: {
        labels: chartData.map(d => d.label),
        datasets: [
          {
            label: 'Masuk',
            data: chartData.map(d => d.in),
            backgroundColor: '#2D7A4F',
            borderRadius: 4,
            barPercentage: 0.6,
          },
          {
            label: 'Keluar',
            data: chartData.map(d => d.out),
            backgroundColor: '#B22222',
            borderRadius: 4,
            barPercentage: 0.6,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 16, font: { size: 11 } } } },
        scales: {
          y: { beginAtZero: true, ticks: { stepSize: 1, font: { size: 11 } }, grid: { color: '#f0f0f0' } },
          x: { ticks: { font: { size: 11 } }, grid: { display: false } },
        },
      },
    });
  }
});
</script>
