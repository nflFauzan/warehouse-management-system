<div class="max-w-lg mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/master/units" class="p-2 rounded-lg hover:bg-gray-100 text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
    <h1 class="text-xl font-bold text-dark-gray"><%= unit ? 'Edit' : 'Tambah' %> Satuan</h1>
  </div>
  <div class="card">
    <form action="<%= unit ? `/master/units/${unit.id}?_method=PUT` : '/master/units' %>" method="POST" class="space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div><label class="form-label">Nama *</label><input type="text" name="name" value="<%= unit ? unit.name : '' %>" required class="form-input" placeholder="Kilogram"></div>
        <div><label class="form-label">Singkatan *</label><input type="text" name="abbr" value="<%= unit ? unit.abbr : '' %>" required class="form-input font-mono" placeholder="kg"></div>
      </div>
      <div class="flex gap-3"><button type="submit" class="btn-primary">Simpan</button><a href="/master/units" class="btn-ghost">Batal</a></div>
    </form>
  </div>
</div>
