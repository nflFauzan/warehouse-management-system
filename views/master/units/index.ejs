<div class="flex items-center justify-between mb-6">
  <div><h1 class="text-xl font-bold text-dark-gray">Master Satuan</h1></div>
  <% if (user && (user.role === 'admin' || user.role === 'owner')) { %>
  <a href="/master/units/create" class="btn-primary flex items-center gap-2"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Tambah</a>
  <% } %>
</div>
<div class="card overflow-hidden p-0">
  <table class="w-full text-sm">
    <thead><tr class="table-header"><th class="text-left py-3 px-4">#</th><th class="text-left py-3 px-4">Nama</th><th class="text-left py-3 px-4">Singkatan</th><th class="text-center py-3 px-4">Aksi</th></tr></thead>
    <tbody>
      <% units.forEach(function(u, i) { %>
      <tr class="border-b border-gray-50 hover:bg-gray-50/50">
        <td class="py-3 px-4 text-gray-400"><%= i+1 %></td>
        <td class="py-3 px-4 font-medium"><%= u.name %></td>
        <td class="py-3 px-4 font-mono text-xs"><%= u.abbr %></td>
        <td class="py-3 px-4 text-center">
          <% if (user && (user.role === 'admin' || user.role === 'owner')) { %>
          <div class="flex items-center justify-center gap-1">
            <a href="/master/units/<%= u.id %>/edit" class="p-1.5 rounded hover:bg-gray-100 text-gray-400 hover:text-yellow-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></a>
            <form action="/master/units/<%= u.id %>?_method=DELETE" method="POST" class="inline" onsubmit="return confirm('Hapus satuan ini?')"><button class="p-1.5 rounded hover:bg-red-50 text-gray-400 hover:text-danger"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button></form>
          </div>
          <% } %>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
