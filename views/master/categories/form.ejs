<div class="max-w-lg mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/master/categories" class="p-2 rounded-lg hover:bg-gray-100 text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
    <h1 class="text-xl font-bold text-dark-gray"><%= category ? 'Edit' : 'Tambah' %> Kategori</h1>
  </div>
  <div class="card">
    <form action="<%= category ? `/master/categories/${category.id}?_method=PUT` : '/master/categories' %>" method="POST" class="space-y-4">
      <div><label class="form-label">Nama Kategori *</label><input type="text" name="name" value="<%= category ? category.name : '' %>" required class="form-input"></div>
      <div class="flex gap-3"><button type="submit" class="btn-primary">Simpan</button><a href="/master/categories" class="btn-ghost">Batal</a></div>
    </form>
  </div>
</div>
