<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/master/customers" class="p-2 rounded-lg hover:bg-gray-100 text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
    <h1 class="text-xl font-bold text-dark-gray"><%= customer ? 'Edit Customer' : 'Tambah Customer' %></h1>
  </div>
  <div class="card">
    <form action="<%= customer ? `/master/customers/${customer.id}?_method=PUT` : '/master/customers' %>" method="POST" class="space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div><label class="form-label">Kode *</label><input type="text" name="code" value="<%= customer ? customer.code : '' %>" required class="form-input font-mono" placeholder="CUS-001"></div>
        <div><label class="form-label">Nama *</label><input type="text" name="name" value="<%= customer ? customer.name : '' %>" required class="form-input"></div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="form-label">Telepon</label><input type="text" name="phone" value="<%= customer ? customer.phone || '' : '' %>" class="form-input"></div>
        <div><label class="form-label">Email</label><input type="email" name="email" value="<%= customer ? customer.email || '' : '' %>" class="form-input"></div>
      </div>
      <div><label class="form-label">Alamat</label><textarea name="address" rows="2" class="form-input"><%= customer ? customer.address || '' : '' %></textarea></div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary"><%= customer ? 'Simpan' : 'Tambah' %></button>
        <a href="/master/customers" class="btn-ghost">Batal</a>
      </div>
    </form>
  </div>
</div>
