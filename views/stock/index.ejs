<!-- Summary Cards -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <div class="card text-center"><p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Total Item</p><p class="text-2xl font-bold font-mono text-dark-gray"><%= summary.total %></p></div>
  <div class="card text-center"><p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Stok Aman</p><p class="text-2xl font-bold font-mono text-success"><%= summary.safe %></p></div>
  <div class="card text-center"><p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Stok Kritis</p><p class="text-2xl font-bold font-mono text-danger"><%= summary.critical %></p></div>
  <div class="card text-center"><p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Stok Habis</p><p class="text-2xl font-bold font-mono text-gray-700"><%= summary.empty %></p></div>
</div>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-xl font-bold text-dark-gray">Posisi Stok</h1>
</div>

<!-- Filters -->
<div class="card mb-4">
  <form method="GET" action="/stock" class="flex flex-wrap gap-3 items-end">
    <div class="flex-1 min-w-[200px]"><input type="text" name="search" value="<%= search %>" placeholder="Cari kode/nama..." class="form-input"></div>
    <div class="w-44">
      <select name="category_id" class="form-select">
        <option value="">Semua Kategori</option>
        <% categories.forEach(function(cat) { %><option value="<%= cat.id %>" <%= category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option><% }); %>
      </select>
    </div>
    <div class="w-36">
      <select name="status" class="form-select">
        <option value="">Semua Status</option>
        <option value="safe" <%= status === 'safe' ? 'selected' : '' %>>Aman</option>
        <option value="critical" <%= status === 'critical' ? 'selected' : '' %>>Kritis</option>
        <option value="empty" <%= status === 'empty' ? 'selected' : '' %>>Habis</option>
      </select>
    </div>
    <button type="submit" class="btn-secondary">Filter</button>
    <a href="/stock" class="btn-ghost">Reset</a>
  </form>
</div>

<!-- Table -->
<div class="card overflow-hidden p-0">
  <table class="w-full text-sm">
    <thead><tr class="table-header">
      <th class="text-left py-3 px-4">Kode</th>
      <th class="text-left py-3 px-4">Nama Barang</th>
      <th class="text-left py-3 px-4">Kategori</th>
      <th class="text-right py-3 px-4">Stok</th>
      <th class="text-right py-3 px-4">Min.</th>
      <th class="text-left py-3 px-4 w-40">Level</th>
      <th class="text-center py-3 px-4">Status</th>
      <th class="text-center py-3 px-4">Riwayat</th>
    </tr></thead>
    <tbody>
      <% if (items.length === 0) { %><tr><td colspan="8" class="text-center py-8 text-gray-400">Tidak ada data</td></tr><% } %>
      <% items.forEach(function(item) { %>
        <%
          const st = item.status;
          const min = parseFloat(item.minimum_stock) || 0;
          const cur = parseFloat(item.current_stock) || 0;
          const pct = min > 0 ? Math.min(100, (cur / min) * 50) : 100;
          const barColor = pct >= 50 ? 'bg-green-600' : (pct >= 25 ? 'bg-yellow-500' : 'bg-red-600');
        %>
      <tr class="border-b border-gray-50 hover:bg-gray-50/50 <%= st === 'critical' ? 'bg-[#FFF5F5]' : st === 'empty' ? 'bg-[#FFFBF0]' : '' %>">
        <td class="py-3 px-4 font-mono text-xs font-medium"><%= item.code %></td>
        <td class="py-3 px-4 font-medium"><%= item.name %></td>
        <td class="py-3 px-4 text-gray-500"><%= item.category ? item.category.name : '-' %></td>
        <td class="py-3 px-4 text-right font-mono font-bold <%= st === 'critical' ? 'text-danger' : '' %>"><%= formatNumber(item.current_stock) %> <span class="text-gray-400 font-normal text-xs"><%= item.unit ? item.unit.abbr : '' %></span></td>
        <td class="py-3 px-4 text-right font-mono text-gray-500"><%= formatNumber(item.minimum_stock) %></td>
        <td class="py-3 px-4">
          <div class="flex items-center gap-2">
            <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden">
              <div class="<%= barColor %> h-full rounded-full" style="width: <%= pct %>%"></div>
            </div>
            <span class="text-xs text-gray-500 w-8 text-right font-mono"><%= Math.round(pct) %>%</span>
          </div>
        </td>
        <td class="py-3 px-4 text-center">
          <% if (st === 'safe') { %><span class="badge-safe">AMAN</span>
          <% } else if (st === 'critical') { %><span class="badge-critical">KRITIS</span>
          <% } else if (st === 'empty') { %><span class="badge-empty">HABIS</span>
          <% } else { %><span class="badge bg-gray-50 text-gray-400 border border-gray-200">—</span><% } %>
        </td>
        <td class="py-3 px-4 text-center">
          <a href="/stock/<%= item.id %>/history" class="text-blue-primary hover:underline text-xs font-medium">Riwayat →</a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% if (totalPages > 1) { %>
  <div class="flex items-center justify-between px-4 py-3 border-t border-gray-100">
    <p class="text-xs text-gray-500"><%= count %> item</p>
    <div class="flex gap-1">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <a href="/stock?page=<%= p %>&search=<%= search %>&category_id=<%= category_id %>&status=<%= status %>" class="px-3 py-1 rounded text-xs font-medium <%= p === currentPage ? 'bg-blue-primary text-white' : 'text-gray-600 hover:bg-gray-100' %>"><%= p %></a>
      <% } %>
    </div>
  </div>
  <% } %>
</div>
