<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/stock" class="p-2 rounded-lg hover:bg-gray-100 text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
    <div>
      <h1 class="text-xl font-bold text-dark-gray">Riwayat Mutasi: <%= item.name %></h1>
      <p class="text-sm text-gray-500"><span class="font-mono"><%= item.code %></span> · <%= item.category ? item.category.name : '' %> · Stok saat ini: <span class="font-mono font-bold"><%= formatNumber(item.current_stock) %></span> <%= item.unit ? item.unit.abbr : '' %></p>
    </div>
  </div>

  <div class="card overflow-hidden p-0">
    <table class="w-full text-sm">
      <thead><tr class="table-header">
        <th class="py-3 px-4 text-left">Tanggal</th>
        <th class="py-3 px-4 text-center">Tipe</th>
        <th class="py-3 px-4 text-right">Qty</th>
        <th class="py-3 px-4 text-right">Stok Sebelum</th>
        <th class="py-3 px-4 text-right">Stok Sesudah</th>
        <th class="py-3 px-4 text-left">Referensi</th>
        <th class="py-3 px-4 text-left">Oleh</th>
      </tr></thead>
      <tbody>
        <% if (mutations.length === 0) { %><tr><td colspan="7" class="text-center py-8 text-gray-400">Belum ada riwayat mutasi</td></tr><% } %>
        <% mutations.forEach(function(m) { %>
        <tr class="border-b border-gray-50 hover:bg-gray-50/50">
          <td class="py-3 px-4 text-gray-500"><%= formatDate(m.created_at) %></td>
          <td class="py-3 px-4 text-center"><span class="<%= m.type === 'in' ? 'badge-in' : 'badge-out' %>"><%= m.type === 'in' ? 'MASUK' : 'KELUAR' %></span></td>
          <td class="py-3 px-4 text-right font-mono font-bold <%= m.type === 'in' ? 'text-success' : 'text-danger' %>"><%= m.type === 'in' ? '+' : '-' %><%= formatNumber(m.quantity) %></td>
          <td class="py-3 px-4 text-right font-mono text-gray-500"><%= formatNumber(m.stock_before) %></td>
          <td class="py-3 px-4 text-right font-mono font-bold"><%= formatNumber(m.stock_after) %></td>
          <td class="py-3 px-4 font-mono text-xs">
            <a href="/transaksi/<%= m.reference_type === 'stock_in' ? 'masuk' : 'keluar' %>/<%= m.reference_id %>" class="text-blue-primary hover:underline"><%= m.reference_type === 'stock_in' ? 'BM' : 'BK' %>-<%= m.reference_id %></a>
          </td>
          <td class="py-3 px-4 text-gray-500"><%= m.createdBy ? m.createdBy.name : '-' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
