<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <a href="/transaksi/masuk" class="p-2 rounded-lg hover:bg-gray-100 text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
      <div>
        <h1 class="text-xl font-bold text-dark-gray">Barang Masuk: <span class="font-mono"><%= stockIn.reference_no %></span></h1>
        <span class="<%= stockIn.status === 'confirmed' ? 'badge-confirmed' : 'badge-draft' %>"><%= stockIn.status === 'confirmed' ? 'CONFIRMED' : 'DRAFT' %></span>
      </div>
    </div>
    <% if (stockIn.status === 'draft' && user && (user.role === 'admin' || user.role === 'owner')) { %>
    <a href="/transaksi/masuk/<%= stockIn.id %>/confirm-action" class="btn-primary" onclick="return confirm('Konfirmasi transaksi ini? Stok akan langsung diperbarui.')">
      Konfirmasi Transaksi
    </a>
    <% } %>
  </div>

  <div class="card mb-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <div><p class="text-gray-400 text-xs uppercase mb-1">Tanggal</p><p class="font-medium"><%= formatDate(stockIn.received_at) %></p></div>
      <div><p class="text-gray-400 text-xs uppercase mb-1">Supplier</p><p class="font-medium"><%= stockIn.supplier ? stockIn.supplier.name : '-' %></p></div>
      <div><p class="text-gray-400 text-xs uppercase mb-1">Diterima Oleh</p><p class="font-medium"><%= stockIn.receivedBy ? stockIn.receivedBy.name : '-' %></p></div>
      <div><p class="text-gray-400 text-xs uppercase mb-1">No. SJ</p><p class="font-medium font-mono"><%= stockIn.supplier_ref || '-' %></p></div>
    </div>
    <% if (stockIn.notes) { %><div class="mt-3 pt-3 border-t border-gray-100 text-sm text-gray-600"><%= stockIn.notes %></div><% } %>
    <% if (stockIn.confirmed_at) { %>
    <div class="mt-3 pt-3 border-t border-gray-100 text-xs text-gray-400">
      Dikonfirmasi oleh <strong><%= stockIn.confirmedBy ? stockIn.confirmedBy.name : '-' %></strong> pada <%= formatDate(stockIn.confirmed_at) %>
    </div>
    <% } %>
  </div>

  <div class="card overflow-hidden p-0">
    <table class="w-full text-sm">
      <thead><tr class="table-header">
        <th class="py-3 px-4 text-left">#</th>
        <th class="py-3 px-4 text-left">Kode</th>
        <th class="py-3 px-4 text-left">Nama Barang</th>
        <th class="py-3 px-4 text-right">Qty</th>
        <th class="py-3 px-4 text-left">Satuan</th>
        <th class="py-3 px-4 text-right">Stok Sebelum</th>
        <th class="py-3 px-4 text-right">Stok Sesudah</th>
      </tr></thead>
      <tbody>
        <% stockIn.items.forEach(function(line, i) { %>
        <tr class="border-b border-gray-50">
          <td class="py-3 px-4 text-gray-400"><%= i+1 %></td>
          <td class="py-3 px-4 font-mono text-xs"><%= line.item ? line.item.code : '-' %></td>
          <td class="py-3 px-4 font-medium"><%= line.item ? line.item.name : '-' %></td>
          <td class="py-3 px-4 text-right font-mono font-bold text-success">+<%= formatNumber(line.quantity) %></td>
          <td class="py-3 px-4 text-gray-500"><%= line.item && line.item.unit ? line.item.unit.abbr : '' %></td>
          <td class="py-3 px-4 text-right font-mono text-gray-500"><%= formatNumber(line.stock_before) %></td>
          <td class="py-3 px-4 text-right font-mono font-bold"><%= formatNumber(line.stock_after) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
