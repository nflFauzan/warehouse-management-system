<div class="max-w-4xl mx-auto" x-data="stockOutForm()">
  <div class="flex items-center gap-3 mb-6">
    <a href="/transaksi/keluar" class="p-2 rounded-lg hover:bg-gray-100 text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
    <div><h1 class="text-xl font-bold text-dark-gray">Tambah Barang Keluar</h1><p class="text-sm text-gray-500">Catat pengeluaran barang ke customer</p></div>
  </div>

  <form method="POST" action="/transaksi/keluar" @submit="beforeSubmit($event)">
    <div class="card mb-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div><label class="form-label">No. Referensi</label><input type="text" name="reference_no" value="<%= refNo %>" readonly class="form-input font-mono bg-gray-50"></div>
        <div><label class="form-label">Tanggal Keluar *</label><input type="date" name="issued_at" value="<%= today %>" required class="form-input"></div>
        <div>
          <label class="form-label">Customer *</label>
          <select name="customer_id" required class="form-select">
            <option value="">Pilih Customer</option>
            <% customers.forEach(function(c) { %><option value="<%= c.id %>"><%= c.name %></option><% }); %>
          </select>
        </div>
      </div>
      <div class="mt-4"><label class="form-label">Catatan</label><textarea name="notes" rows="2" class="form-input" placeholder="Opsional"></textarea></div>
    </div>

    <div class="card mb-4">
      <h3 class="text-sm font-bold text-dark-gray uppercase tracking-wider mb-4">Detail Barang</h3>
      <div class="w-full">
        <table class="w-full text-sm">
          <thead><tr class="table-header">
            <th class="py-2 px-3 text-left w-8">#</th><th class="py-2 px-3 text-left">Barang</th>
            <th class="py-2 px-3 text-right w-28">Qty</th><th class="py-2 px-3 text-left w-20">Satuan</th>
            <th class="py-2 px-3 text-right w-28">Stok Saat Ini</th><th class="py-2 px-3 text-right w-28">Sisa Stok</th><th class="py-2 px-3 w-10"></th>
          </tr></thead>
          <tbody>
            <template x-for="(row, index) in rows" :key="index">
              <tr class="border-b border-gray-50">
                <td class="py-2 px-3 text-gray-400" x-text="index + 1"></td>
                <td class="py-2 px-3 relative" :style="row.showDropdown ? 'z-index: 50;' : ''">
                  <input type="hidden" :name="`items[${index}][item_id]`" x-model="row.item_id">
                  <input type="text" x-model="row.search"
                         @input="debouncedSearch(index)"
                         @focus="onFocus(index)"
                         @keydown.escape="row.showDropdown = false"
                         @keydown.arrow-down.prevent="highlightNext(index)"
                         @keydown.arrow-up.prevent="highlightPrev(index)"
                         @keydown.enter.prevent="selectHighlighted(index)"
                         class="form-input text-sm" placeholder="Ketik kode/nama barang..."
                         autocomplete="off">
                  <!-- Dropdown -->
                  <div x-show="row.showDropdown" @click.outside="row.showDropdown = false"
                       class="absolute z-10 left-3 right-3 top-full bg-white border border-gray-200 rounded-lg shadow-lg max-h-48 overflow-y-auto">
                    <!-- Loading -->
                    <div x-show="row.loading" class="px-3 py-3 text-sm text-gray-400 flex items-center gap-2">
                      <svg class="animate-spin h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                      </svg>
                      Mencari...
                    </div>
                    <!-- Results -->
                    <template x-if="!row.loading && row.results.length > 0">
                      <div>
                        <template x-for="(item, idx) in row.results" :key="item.id">
                          <button type="button" @click="selectItem(index, item)"
                                  @mouseenter="row.highlightIndex = idx"
                                  :class="row.highlightIndex === idx ? 'bg-blue-50' : ''"
                                  class="w-full text-left px-3 py-2 hover:bg-blue-50 text-sm flex justify-between items-center transition-colors">
                            <span>
                              <span class="font-mono text-xs text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded" x-text="item.code"></span>
                              <span class="ml-2" x-text="item.name"></span>
                            </span>
                            <span class="font-mono text-xs text-gray-400 flex-shrink-0 ml-2" x-text="item.current_stock + ' ' + item.unit"></span>
                          </button>
                        </template>
                      </div>
                    </template>
                    <!-- No results -->
                    <div x-show="!row.loading && row.results.length === 0 && row.searched" class="px-3 py-3 text-sm text-gray-400 text-center">
                      <svg class="w-5 h-5 mx-auto mb-1 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                      Barang tidak ditemukan
                    </div>
                  </div>
                </td>
                <td class="py-2 px-3"><input type="number" :name="`items[${index}][quantity]`" x-model="row.quantity" @input="calcAfter(index)" min="0.01" step="0.01" class="form-input text-right font-mono w-28"></td>
                <td class="py-2 px-3 font-mono text-xs text-gray-500" x-text="row.unit"></td>
                <td class="py-2 px-3 text-right font-mono text-gray-500" x-text="formatNum(row.stock_before)"></td>
                <td class="py-2 px-3 text-right font-mono font-bold" :class="row.stock_after < 0 ? 'text-danger' : 'text-dark-gray'" x-text="formatNum(row.stock_after)"></td>
                <td class="py-2 px-3"><button type="button" @click="removeRow(index)" class="p-1 rounded hover:bg-red-50 text-gray-400 hover:text-danger" x-show="rows.length > 1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
      <button type="button" @click="addRow()" class="mt-3 text-sm text-blue-primary hover:underline font-medium flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Tambah Baris
      </button>
    </div>

    <div class="flex gap-3">
      <button type="submit" name="action" value="draft" class="btn-ghost">Simpan Draft</button>
      <% if (user && (user.role === 'admin' || user.role === 'owner')) { %>
      <button type="submit" name="action" value="confirm" class="btn-primary" onclick="return confirm('Konfirmasi? Stok akan langsung berkurang.')">Konfirmasi & Simpan</button>
      <% } %>
    </div>
  </form>
</div>
<script>
function stockOutForm() {
  let _debounceTimers = {};
  return {
    rows: [{ item_id: '', search: '', quantity: '', unit: '', stock_before: 0, stock_after: 0, results: [], showDropdown: false, loading: false, searched: false, highlightIndex: -1 }],

    addRow() {
      this.rows.push({ item_id: '', search: '', quantity: '', unit: '', stock_before: 0, stock_after: 0, results: [], showDropdown: false, loading: false, searched: false, highlightIndex: -1 });
    },

    removeRow(i) { this.rows.splice(i, 1); },

    debouncedSearch(i) {
      this.rows[i].item_id = '';
      this.rows[i].unit = '';
      this.rows[i].stock_before = 0;
      this.rows[i].stock_after = 0;

      clearTimeout(_debounceTimers[i]);
      _debounceTimers[i] = setTimeout(() => this.searchItems(i), 250);
    },

    async onFocus(i) {
      if (this.rows[i].results.length === 0 && !this.rows[i].item_id) {
        await this.searchItems(i);
      }
      this.rows[i].showDropdown = true;
    },

    async searchItems(i) {
      const q = this.rows[i].search;
      this.rows[i].loading = true;
      this.rows[i].showDropdown = true;
      this.rows[i].highlightIndex = -1;
      try {
        const res = await fetch(`/api/items/search?q=${encodeURIComponent(q)}`);
        const data = await res.json();
        this.rows[i].results = Array.isArray(data) ? data : [];
        this.rows[i].searched = true;
      } catch(e) {
        console.error(e);
        this.rows[i].results = [];
      } finally {
        this.rows[i].loading = false;
      }
    },

    highlightNext(i) {
      const row = this.rows[i];
      if (row.results.length === 0) return;
      row.highlightIndex = (row.highlightIndex + 1) % row.results.length;
    },

    highlightPrev(i) {
      const row = this.rows[i];
      if (row.results.length === 0) return;
      row.highlightIndex = row.highlightIndex <= 0 ? row.results.length - 1 : row.highlightIndex - 1;
    },

    selectHighlighted(i) {
      const row = this.rows[i];
      if (row.highlightIndex >= 0 && row.highlightIndex < row.results.length) {
        this.selectItem(i, row.results[row.highlightIndex]);
      }
    },

    selectItem(i, item) {
      this.rows[i].item_id = item.id;
      this.rows[i].search = `${item.code} — ${item.name}`;
      this.rows[i].unit = item.unit;
      this.rows[i].stock_before = parseFloat(item.current_stock) || 0;
      this.rows[i].showDropdown = false;
      this.rows[i].results = [];
      this.rows[i].searched = false;
      this.rows[i].highlightIndex = -1;
      this.calcAfter(i);
    },

    calcAfter(i) {
      const before = parseFloat(this.rows[i].stock_before) || 0;
      this.rows[i].stock_after = before - (parseFloat(this.rows[i].quantity) || 0);
    },

    formatNum(n) { return (parseFloat(n) || 0).toLocaleString('id-ID'); },

    beforeSubmit(e) {
      const hasValidItem = this.rows.some(r => r.item_id && parseFloat(r.quantity) > 0);
      if (!hasValidItem) {
        e.preventDefault();
        alert('Tambahkan minimal satu barang dengan qty lebih dari 0.');
        return false;
      }
    }
  };
}
</script>
