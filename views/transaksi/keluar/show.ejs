<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <a href="/transaksi/keluar" class="p-2 rounded-lg hover:bg-gray-100 text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
      <div>
        <h1 class="text-xl font-bold text-dark-gray">Barang Keluar: <span class="font-mono"><%= stockOut.reference_no %></span></h1>
        <span class="<%= stockOut.status === 'confirmed' ? 'badge-confirmed' : 'badge-draft' %>"><%= stockOut.status === 'confirmed' ? 'CONFIRMED' : 'DRAFT' %></span>
      </div>
    </div>
    <% if (stockOut.status === 'draft' && user && (user.role === 'admin' || user.role === 'owner')) { %>
    <a href="/transaksi/keluar/<%= stockOut.id %>/confirm-action" class="btn-primary" onclick="return confirm('Konfirmasi? Stok akan langsung berkurang.')">Konfirmasi Transaksi</a>
    <% } %>
  </div>
  <div class="card mb-4">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
      <div><p class="text-gray-400 text-xs uppercase mb-1">Tanggal</p><p class="font-medium"><%= formatDate(stockOut.issued_at) %></p></div>
      <div><p class="text-gray-400 text-xs uppercase mb-1">Customer</p><p class="font-medium"><%= stockOut.customer ? stockOut.customer.name : '-' %></p></div>
      <div><p class="text-gray-400 text-xs uppercase mb-1">Dikeluarkan Oleh</p><p class="font-medium"><%= stockOut.issuedBy ? stockOut.issuedBy.name : '-' %></p></div>
    </div>
    <% if (stockOut.notes) { %><div class="mt-3 pt-3 border-t border-gray-100 text-sm text-gray-600"><%= stockOut.notes %></div><% } %>
    <% if (stockOut.confirmed_at) { %>
    <div class="mt-3 pt-3 border-t border-gray-100 text-xs text-gray-400">Dikonfirmasi oleh <strong><%= stockOut.confirmedBy ? stockOut.confirmedBy.name : '-' %></strong> pada <%= formatDate(stockOut.confirmed_at) %></div>
    <% } %>
  </div>
  <div class="card overflow-hidden p-0">
    <table class="w-full text-sm">
      <thead><tr class="table-header">
        <th class="py-3 px-4 text-left">#</th><th class="py-3 px-4 text-left">Kode</th><th class="py-3 px-4 text-left">Nama Barang</th>
        <th class="py-3 px-4 text-right">Qty</th><th class="py-3 px-4 text-left">Satuan</th>
        <th class="py-3 px-4 text-right">Stok Sebelum</th><th class="py-3 px-4 text-right">Stok Sesudah</th>
      </tr></thead>
      <tbody>
        <% stockOut.items.forEach(function(line, i) { %>
        <tr class="border-b border-gray-50">
          <td class="py-3 px-4 text-gray-400"><%= i+1 %></td>
          <td class="py-3 px-4 font-mono text-xs"><%= line.item ? line.item.code : '-' %></td>
          <td class="py-3 px-4 font-medium"><%= line.item ? line.item.name : '-' %></td>
          <td class="py-3 px-4 text-right font-mono font-bold text-danger">-<%= formatNumber(line.quantity) %></td>
          <td class="py-3 px-4 text-gray-500"><%= line.item && line.item.unit ? line.item.unit.abbr : '' %></td>
          <td class="py-3 px-4 text-right font-mono text-gray-500"><%= formatNumber(line.stock_before) %></td>
          <td class="py-3 px-4 text-right font-mono font-bold"><%= formatNumber(line.stock_after) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
