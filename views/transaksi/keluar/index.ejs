<div class="flex items-center justify-between mb-6">
  <div><h1 class="text-xl font-bold text-dark-gray">Barang Keluar</h1><p class="text-sm text-gray-500">Daftar transaksi barang keluar</p></div>
  <a href="/transaksi/keluar/create" class="btn-primary flex items-center gap-2"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Buat Baru</a>
</div>
<div class="card overflow-hidden p-0">
  <table class="w-full text-sm">
    <thead><tr class="table-header">
      <th class="text-left py-3 px-4">No. Referensi</th>
      <th class="text-left py-3 px-4">Tanggal</th>
      <th class="text-left py-3 px-4">Customer</th>
      <th class="text-left py-3 px-4">Dikeluarkan Oleh</th>
      <th class="text-center py-3 px-4">Status</th>
      <th class="text-center py-3 px-4">Detail</th>
    </tr></thead>
    <tbody>
      <% if (stockOuts.length === 0) { %><tr><td colspan="6" class="text-center py-8 text-gray-400">Belum ada transaksi</td></tr><% } %>
      <% stockOuts.forEach(function(so) { %>
      <tr class="border-b border-gray-50 hover:bg-gray-50/50">
        <td class="py-3 px-4 font-mono text-xs font-semibold text-blue-primary"><%= so.reference_no %></td>
        <td class="py-3 px-4"><%= formatDate(so.issued_at) %></td>
        <td class="py-3 px-4"><%= so.customer ? so.customer.name : '-' %></td>
        <td class="py-3 px-4 text-gray-500"><%= so.issuedBy ? so.issuedBy.name : '-' %></td>
        <td class="py-3 px-4 text-center"><span class="<%= so.status === 'confirmed' ? 'badge-confirmed' : 'badge-draft' %>"><%= so.status === 'confirmed' ? 'CONFIRMED' : 'DRAFT' %></span></td>
        <td class="py-3 px-4 text-center"><a href="/transaksi/keluar/<%= so.id %>" class="text-blue-primary hover:underline text-xs font-medium">Lihat →</a></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
