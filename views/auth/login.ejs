<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — TAKKA STEEL</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="h-full font-sans flex">
  <!-- Left Panel: Blue branding -->
  <div class="hidden lg:flex lg:w-1/2 bg-blue-primary relative flex-col items-center justify-center p-12">
    <div class="text-center">
      <img src="/images/logo.png" alt="TAKKA STEEL" class="h-24 w-auto object-contain mx-auto mb-6">
      <h1 class="text-white text-2xl font-bold tracking-wide mb-2">Warehouse Management System</h1>
      <p class="text-white/60 text-sm max-w-xs mx-auto">Sistem manajemen inventaris gudang untuk mengelola stok barang secara efisien dan akurat.</p>
    </div>
    <!-- Decorative circles -->
    <div class="absolute top-10 left-10 w-32 h-32 border border-white/10 rounded-full"></div>
    <div class="absolute bottom-20 right-16 w-48 h-48 border border-white/10 rounded-full"></div>
    <div class="absolute top-1/4 right-10 w-20 h-20 border border-white/10 rounded-full"></div>
  </div>

  <!-- Right Panel: Login form -->
  <div class="flex-1 flex items-center justify-center bg-light-gray p-6">
    <div class="w-full max-w-md">
      <!-- Mobile logo (hidden on desktop) -->
      <div class="text-center mb-8 lg:hidden">
        <img src="/images/logo.png" alt="TAKKA STEEL" class="h-16 w-auto object-contain mx-auto mb-3">
        <p class="text-gray-400 text-sm">Warehouse Management System</p>
      </div>

      <!-- Login Card -->
      <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
        <h2 class="text-xl font-bold text-dark-gray mb-1">Masuk ke Akun</h2>
        <p class="text-gray-400 text-sm mb-6">Silakan masukkan kredensial Anda</p>

        <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
          <% error.forEach(function(msg) { %>
            <div class="mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-danger px-4 py-3 rounded-lg text-sm">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <%= msg %>
            </div>
          <% }); %>
        <% } %>

        <form action="/login" method="POST" class="space-y-5">
          <div>
            <label for="login-email" class="form-label">Email</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/></svg>
              </span>
              <input type="email" name="email" id="login-email" required autofocus
                     class="form-input pl-10" placeholder="nama@takka.com">
            </div>
          </div>
          <div>
            <label for="login-password" class="form-label">Password</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              </span>
              <input type="password" name="password" id="login-password" required
                     class="form-input pl-10" placeholder="••••••••">
            </div>
          </div>
          <button type="submit" id="login-submit" class="w-full text-center py-3 bg-blue-primary text-white font-semibold rounded-lg hover:brightness-110 hover:shadow-md transition-all text-sm">
            Masuk
          </button>
        </form>

        <div class="mt-6 pt-4 border-t border-gray-100">
          <p class="text-xs text-gray-400 text-center mb-2">Demo Login:</p>
          <div class="grid grid-cols-3 gap-2">
            <div class="bg-light-gray rounded-lg px-3 py-2 text-center">
              <p class="text-[10px] text-gray-400 font-medium uppercase">Owner</p>
              <p class="text-[11px] text-gray-600 font-mono mt-0.5">owner@takka.com</p>
            </div>
            <div class="bg-light-gray rounded-lg px-3 py-2 text-center">
              <p class="text-[10px] text-gray-400 font-medium uppercase">Admin</p>
              <p class="text-[11px] text-gray-600 font-mono mt-0.5">admin@takka.com</p>
            </div>
            <div class="bg-light-gray rounded-lg px-3 py-2 text-center">
              <p class="text-[10px] text-gray-400 font-medium uppercase">Staff</p>
              <p class="text-[11px] text-gray-600 font-mono mt-0.5">staff@takka.com</p>
            </div>
          </div>
          <p class="text-[10px] text-gray-400 text-center mt-2">Password: <span class="font-mono">password</span></p>
        </div>
      </div>

      <p class="text-center text-gray-400 text-xs mt-6">© 2025 TAKKA STEEL. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
