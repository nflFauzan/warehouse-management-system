<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — TAKKA STEEL</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="h-full bg-dark-gray font-sans flex items-center justify-center">
  <div class="w-full max-w-md mx-4">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-3 mb-2">
        <div class="w-12 h-12 bg-yellow-accent rounded-xl flex items-center justify-center shadow-lg">
          <span class="text-dark-gray font-extrabold text-xl">T</span>
        </div>
      </div>
      <h1 class="text-3xl font-bold">
        <span class="text-white">TAKKA</span>
        <span class="text-yellow-accent">STEEL</span>
      </h1>
      <p class="text-gray-400 text-sm mt-1">Warehouse Management System</p>
    </div>

    <!-- Login Card -->
    <div class="bg-white rounded-2xl shadow-2xl p-8">
      <h2 class="text-xl font-bold text-dark-gray mb-1">Masuk ke Akun</h2>
      <p class="text-gray-500 text-sm mb-6">Silakan masukkan kredensial Anda</p>

      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <% error.forEach(function(msg) { %>
          <div class="mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-danger px-4 py-3 rounded-lg text-sm">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <%= msg %>
          </div>
        <% }); %>
      <% } %>

      <form action="/login" method="POST" class="space-y-4">
        <div>
          <label for="login-email" class="form-label">Email</label>
          <input type="email" name="email" id="login-email" required autofocus
                 class="form-input" placeholder="nama@takka.com">
        </div>
        <div>
          <label for="login-password" class="form-label">Password</label>
          <input type="password" name="password" id="login-password" required
                 class="form-input" placeholder="••••••••">
        </div>
        <button type="submit" id="login-submit" class="btn-primary w-full text-center py-3">
          Masuk
        </button>
      </form>

      <div class="mt-6 pt-4 border-t border-gray-100">
        <p class="text-xs text-gray-400 text-center">Demo Login:</p>
        <div class="mt-2 space-y-1 text-xs text-gray-500 font-mono text-center">
          <p>owner@takka.com / password</p>
          <p>admin@takka.com / password</p>
          <p>staff@takka.com / password</p>
        </div>
      </div>
    </div>

    <p class="text-center text-gray-500 text-xs mt-6">© 2025 TAKKA STEEL. All rights reserved.</p>
  </div>
</body>
</html>
